// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum ProgramStatus {
  ASSIGNED_TO_UNIT
  DRAFT
  SUBMITTED
  REVISION
  APPROVED
  REJECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ActivityStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  DELAYED
  CANCELLED
}

enum ApprovalStatus {
  DRAFT
  SUBMITTED
  REVISION
  APPROVED
  REJECTED
  COMPLETED
}

enum ProgramMemberRole {
  PIC
  MEMBER
  REVIEWER
}

// ============================================================================
// MODELS
// ============================================================================

/// Program Category (e.g., Research, Community Service, etc.)
model ProgramCategory {
  id          String   @id @default(uuid())
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("program_categories")
}

/// Program Kerja (Work Program)
model Program {
  id          String        @id @default(uuid())
  code        String        @unique @db.VarChar(50)
  title       String        @db.VarChar(255)
  description String?       @db.Text
  objective   String?       @db.Text
  year        Int

  createdBy String   @map("created_by")
  updatedBy String?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  activities Activity[]
  members    ProgramMember[]
  approvals  Approval[]
  indicators ProgramIndicator[]

  @@index([year])
  @@map("programs")
}

/// Program Indicator (Assigned to Unit)
model ProgramIndicator {
  id          String   @id @default(uuid())
  programId   String   @map("program_id")
  unitId      String   @map("unit_id")
  name        String        @db.VarChar(255)
  unit        String        @db.VarChar(50) // e.g. "Dokumen", "Persen"
  targetQ1    Decimal?      @map("target_q1") @db.Decimal(10, 2)
  targetQ2    Decimal?      @map("target_q2") @db.Decimal(10, 2)
  targetQ3    Decimal?      @map("target_q3") @db.Decimal(10, 2)
  targetQ4    Decimal?      @map("target_q4") @db.Decimal(10, 2)
  status      ProgramStatus @default(DRAFT)
  order       Int           @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  program      Program                       @relation(fields: [programId], references: [id], onDelete: Cascade)
  realizations ProgramIndicatorRealization[]
  
  @@index([programId])
  @@index([unitId])
  @@map("program_indicators")
}

/// Program Indicator Realization per month
model ProgramIndicatorRealization {
  id          String   @id @default(uuid())
  indicatorId String   @map("indicator_id")
  month       Int      @db.SmallInt
  realization Decimal  @db.Decimal(10, 2)
  remark      String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  indicator   ProgramIndicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)

  @@unique([indicatorId, month])
  @@index([indicatorId])
  @@map("program_indicator_realizations")
}

/// Program Member assignment
model ProgramMember {
  id        String            @id @default(uuid())
  programId String            @map("program_id")
  userId    String            @map("user_id")
  role      ProgramMemberRole
  createdAt DateTime          @default(now()) @map("created_at")

  // Relations
  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([programId, userId, role])
  @@index([userId])
  @@map("program_members")
}

/// Activity within a Program
model Activity {
  id          String         @id @default(uuid())
  programId   String         @map("program_id")
  title       String         @db.VarChar(255)
  description String?        @db.Text
  weight      Decimal        @default(0) @db.Decimal(5, 2)
  status      ActivityStatus @default(NOT_STARTED)
  startDate   DateTime       @map("start_date")
  endDate     DateTime       @map("end_date")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  // Relations
  program      Program       @relation(fields: [programId], references: [id], onDelete: Cascade)
  outputs      Output[]
  progressLogs ProgressLog[]
  evidences    Evidence[]

  @@index([programId])
  @@index([status])
  @@map("activities")
}

/// Output / deliverable of an Activity
model Output {
  id          String   @id @default(uuid())
  activityId  String   @map("activity_id")
  metricType  String   @map("metric_type") @db.VarChar(100)
  target      Decimal  @db.Decimal(10, 2)
  realization Decimal  @default(0) @db.Decimal(10, 2)
  unit        String   @db.VarChar(50)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId])
  @@map("outputs")
}

/// Progress log (append-only)
model ProgressLog {
  id         String   @id @default(uuid())
  activityId String   @map("activity_id")
  progress   Int      @db.SmallInt
  note       String?  @db.Text
  createdBy  String   @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId])
  @@index([createdAt])
  @@map("progress_logs")
}

/// Evidence / supporting document
model Evidence {
  id         String   @id @default(uuid())
  activityId String   @map("activity_id")
  fileName   String   @map("file_name") @db.VarChar(255)
  filePath   String   @map("file_path") @db.VarChar(500)
  mimeType   String   @map("mime_type") @db.VarChar(100)
  fileSize   Int      @map("file_size")
  uploadedBy String   @map("uploaded_by")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId])
  @@map("evidences")
}

/// Approval workflow entry
model Approval {
  id         String         @id @default(uuid())
  programId  String         @map("program_id")
  status     ApprovalStatus @default(DRAFT)
  level      Int            @default(1) @db.SmallInt
  approverId String?        @map("approver_id")
  note       String?        @db.Text
  approvedAt DateTime?      @map("approved_at")
  createdAt  DateTime       @default(now()) @map("created_at")

  // Relations
  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId])
  @@index([approverId])
  @@index([status])
  @@map("approvals")
}

// ============================================================================
// AUDIT LOG
// ============================================================================

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  APPROVE
  REJECT
  SUBMIT
}

/// Audit Log — records all significant user actions
model AuditLog {
  id         String      @id @default(uuid())
  action     AuditAction
  entityType String      @map("entity_type") @db.VarChar(100)
  entityId   String      @map("entity_id") @db.VarChar(100)
  userId     String      @map("user_id")
  userName   String?     @map("user_name") @db.VarChar(255)
  oldValue   Json?       @map("old_value")
  newValue   Json?       @map("new_value")
  ipAddress  String?     @map("ip_address") @db.VarChar(45)
  userAgent  String?     @map("user_agent") @db.VarChar(500)
  createdAt  DateTime    @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================================
// DEFAULT PROGRAM (IKU Mapping)
// ============================================================================

/// Default program template mapping for IKU (Integration with SIM IKU)
model DefaultProgram {
  id          String   @id @default(uuid())
  ikuId       String   @map("iku_id") @db.VarChar(100)
  ikuCode     String   @map("iku_code") @db.VarChar(50)
  title       String   @db.VarChar(255)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  indicators  DefaultProgramIndicator[]

  @@index([ikuId])
  @@index([ikuCode])
  @@map("default_programs")
}

/// Default program indicator template
model DefaultProgramIndicator {
  id               String         @id @default(uuid())
  defaultProgramId String         @map("default_program_id")
  name             String         @db.VarChar(255)
  unit             String         @db.VarChar(50) // e.g. "Dokumen", "Persen"
  order            Int            @default(0)
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  defaultProgram   DefaultProgram @relation(fields: [defaultProgramId], references: [id], onDelete: Cascade)
  
  @@index([defaultProgramId])
  @@map("default_program_indicators")
}
